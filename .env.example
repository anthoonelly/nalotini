# =====================================================
# Wymagane zmienne środowiskowe (skonfiguruj w Vercel)
# =====================================================

# 1) Baza danych - po podłączeniu integracji Neon w Vercel
#    zmienne DATABASE_URL i POSTGRES_URL pojawią się automatycznie.
#    Nie musisz wpisywać ich ręcznie.
DATABASE_URL=

# 2) NextAuth - sekret do podpisywania sesji (JWT).
#    Wygeneruj losowy ciąg 32+ znaków (Vercel ma przycisk "Generate")
NEXTAUTH_SECRET=

# 3) Adres produkcji (np. https://nalotini.vercel.app)
#    Vercel wstawi go automatycznie jako VERCEL_URL,
#    ale dla NextAuth musisz dodać własny NEXTAUTH_URL
NEXTAUTH_URL=

# 4) Konto administratora seedowane przy pierwszym uruchomieniu
ADMIN_EMAIL=admin@nalotini.pl
ADMIN_PASSWORD=ZmienToMocneHaslo123!
ADMIN_NAME=Administrator
